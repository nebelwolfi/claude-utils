{
  "name": "kanban-mcp",
  "version": "1.0.0",
  "description": "Kanban board MCP server with markdown-based storage",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "kanban-mcp": "dist/index.js",
    "kanban-web": "dist/web.js"
  },
  "scripts": {
    "build": "tsc && node -e \"require('fs').copyFileSync('src/app.html','dist/app.html')\"",
    "prepare": "npm run build",
    "start": "node dist/index.js",
    "web": "node dist/web.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  }
}
