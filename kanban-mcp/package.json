{
  "name": "kanban-mcp",
  "version": "1.0.0",
  "description": "Kanban board MCP server with markdown-based storage",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./storage": "./dist/storage.js",
    "./operations": "./dist/operations.js",
    "./parsers": "./dist/parsers.js",
    "./helpers": "./dist/helpers.js",
    "./types": "./dist/types.js",
    "./views": "./dist/views.js"
  },
  "installConfig": {
    "displayName": "Kanban Board MCP",
    "prerequisites": []
  },
  "bin": {
    "Kanban-Open": "dist/web.js",
    "kanban": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc && node -e \"require('fs').copyFileSync('src/app.html','dist/app.html')\"",
    "prepare": "npm run build",
    "start": "node dist/index.js",
    "web": "node dist/web.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  }
}
